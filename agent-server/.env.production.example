# ============================================================
# BARBEAR-FLOW: Variáveis de Ambiente - PRODUÇÃO
# ============================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.production
# 2. Substitua TODOS os valores placeholder pelos valores reais
# 3. NUNCA commit este arquivo no git
# 4. Use Railway / Docker secrets ou variáveis de ambiente do hosting
# ============================================================

# ============================================================
# SERVER
# ============================================================
PORT=3000
NODE_ENV=production

# ============================================================
# DATABASE (PostgreSQL via Supabase)
# ============================================================
# NÃO use localhost em produção
# Codifique @ na senha como %40
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.seu-project.supabase.co:5432/postgres

# ============================================================
# UPSTASH REDIS (Sessão do Agente)
# ============================================================
UPSTASH_REDIS_REST_URL=https://seu-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=SEU_TOKEN_AQUI

# ============================================================
# EVOLUTION API (WhatsApp Gateway)
# ============================================================
EVOLUTION_API_URL=https://evolution-api.seu-dominio.com
EVOLUTION_API_KEY=SUA_API_KEY_AQUI
EVOLUTION_INSTANCE_NAME=barbear-flow

# ============================================================
# LLMs (Inteligência Artificial)
# ============================================================
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-SEU_TOKEN_AQUI

# Modelo LLM padrão
LLM_MODEL=claude-sonnet-4-5-20250514

# OpenAI (Whisper - transcrição de áudio)
OPENAI_API_KEY=sk-proj-SEU_TOKEN_AQUI

# ============================================================
# SECURITY (CRÍTICO EM PRODUÇÃO)
# ============================================================
# Gere com: openssl rand -hex 32
WEBHOOK_SECRET=SEU_HMAC_SECRET_AQUI

# Gere com: openssl rand -hex 32
API_SECRET_KEY=SEU_API_KEY_AQUI

# Defina explicitamente os domínios permitidos (separados por vírgula)
# NÃO use * em produção
CORS_ALLOWED_ORIGINS=https://app.barbearflow.com,https://admin.barbearflow.com

# ============================================================
# TIMEOUTS (ms)
# ============================================================
EVOLUTION_API_TIMEOUT_MS=30000
ANTHROPIC_API_TIMEOUT_MS=60000
OPENAI_API_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_MAX=20

# ============================================================
# SCHEDULER (Follow-ups automáticos)
# ============================================================
FOLLOW_UP_SEND_INTERVAL_MS=500
FOLLOW_UP_MAX_PER_EXECUTION=100

# ============================================================
# LOGGING
# ============================================================
# Em produção, use 'info' ou 'warn' (não 'debug')
LOG_LEVEL=info
