# ============================================================
# BARBEAR-FLOW: Variáveis de Ambiente (Template)
# Copie para .env e preencha os valores
# ============================================================

# ============================================================
# SERVER
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# DATABASE (PostgreSQL via Supabase)
# ============================================================
# Connection string para Drizzle ORM
# Formato: postgresql://user:password@host:port/dbname
# Se a senha contiver @, codifique como %40
DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@db.seu-project.supabase.co:5432/postgres

# ============================================================
# UPSTASH REDIS (Sessão do Agente)
# ============================================================
UPSTASH_REDIS_REST_URL=https://seu-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu-token-aqui

# ============================================================
# EVOLUTION API (WhatsApp Gateway)
# ============================================================
EVOLUTION_API_URL=https://evolution-api.seu-dominio.com
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE_NAME=barbear-flow

# ============================================================
# LLMs (Inteligência Artificial)
# ============================================================
# Anthropic Claude (modelo principal com tool use nativo)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modelo LLM padrão
LLM_MODEL=claude-sonnet-4-5-20250514

# OpenAI (usado apenas para Whisper - transcrição de áudio)
# Se ausente, o serviço de transcrição fica desabilitado (graceful degrade)
OPENAI_API_KEY=sk-proj-...

# ============================================================
# WEBHOOK
# ============================================================
# Secret HMAC para validar assinatura do webhook
# Gere um valor aleatório forte (mínimo 32 caracteres)
# Ex: openssl rand -hex 32
WEBHOOK_SECRET=

# ============================================================
# SECURITY
# ============================================================
# API Key para proteger rotas administrativas
# Se ausente, as rotas de conversas ficam abertas (não recomendado em produção)
API_SECRET_KEY=

# Origens permitidas para CORS (separadas por vírgula)
# Em produção, defina explicitamente os domínios permitidos
# Ex: https://app.barbearflow.com,https://admin.barbearflow.com
CORS_ALLOWED_ORIGINS=*

# ============================================================
# SCHEDULER (Follow-ups automáticos)
# ============================================================
# Intervalo entre envios de follow-up (ms) - evitar spam
FOLLOW_UP_SEND_INTERVAL_MS=500

# Limite de follow-ups por execução
FOLLOW_UP_MAX_PER_EXECUTION=100

# ============================================================
# TIMEOUTS (ms) - Chamadas a serviços externos
# ============================================================
EVOLUTION_API_TIMEOUT_MS=30000
ANTHROPIC_API_TIMEOUT_MS=60000
OPENAI_API_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000

# ============================================================
# DATABASE POOL
# ============================================================
DATABASE_POOL_MAX=20

# ============================================================
# LOGGING
# ============================================================
# Níveis: fatal, error, warn, info (default), debug, trace, silent
# Em produção, use 'info' ou 'warn'
LOG_LEVEL=debug
