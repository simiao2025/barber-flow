.env.local
.env.production
.env.development.local
.env.production.local
*.env

# Dependencies
node_modules/

# Build outputs
dist/
build/
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# OS temp
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Expo / Mobile
barber-app/.expo/
barber-app/.expo-shared/

# Supabase local dev
supabase/.temp/
supabase/.branches/

