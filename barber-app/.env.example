# ============================================================
# BarberFlow - Variáveis de Ambiente do App Mobile (Expo)
# ============================================================
# Prefixo EXPO_PUBLIC_ é necessário para variáveis acessíveis no client
# ============================================================

# ============================================================
# SUPABASE (Client-side)
# ============================================================
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ============================================================
# EXPO PUSH NOTIFICATIONS (EAS)
# ============================================================
EXPO_PUBLIC_EXPO_PROJECT_ID=your-project-id

# ============================================================
# API URL (Agent Server)
# ============================================================
# URL do servidor agent-server para chamadas HTTP do app
EXPO_PUBLIC_API_URL=https://api.barbearflow.com
